  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.3",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^22.14.0",
    "@types/nodemailer": "^6.4.17",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.0",
    "@types/react-dom": "^19.1.1",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9.1.2",
    "pdf-parse": "^2.4.5",
    "prisma": "^6.5.0",
    "tailwindcss": "^4.1.3",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
