    "db:push": "prisma db push",
    "db:seed": "tsx prisma/seed.ts",
    "import:busy": "tsx prisma/import-busy-stock.ts",
    "assign:images": "tsx prisma/assign-product-images.ts",
    "extract:pdf": "node scripts/extract-pdf.cjs",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@prisma/client": "^6.5.0",
    "bcryptjs": "^3.0.2",
    "bwip-js": "^4.5.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.6.3",
    "jose": "^6.0.10",
    "lucide-react": "^0.487.0",
    "next": "^15.2.4",
    "nodemailer": "^6.10.0",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "tailwind-merge": "^3.1.0",
    "uuid": "^11.1.0",
    "zod": "^3.24.2"
